
# Copy to .env and fill in your keys
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=pcn-...
# For Pinecone v4, you typically use a HOST + index name.
PINECONE_HOST=YOUR_INDEX-yourproject.svc.YOUR_REGION.pinecone.io
PINECONE_INDEX=gmpx-retrieval
# Optional: region/project if using older SDKs or specialized setups
PINECONE_PROJECT=
PINECONE_REGION=
